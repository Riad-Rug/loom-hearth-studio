generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductCategory {
  rugs
  poufs
  pillows
  decor
  vintage
}

enum AdminRole {
  admin
  editor
  viewer
}

enum CheckoutMode {
  guest
}

enum OrderStatus {
  pending
  paid
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  authorized
  paid
  failed
  refunded
}

enum PromoType {
  percent
  fixed
}

enum PromoScopeType {
  all
  category
  product
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  firstName     String?
  lastName      String?
  role          AdminRole?
  accounts      Account[]
  passwordResetTokens PasswordResetToken[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LoginRateLimitAttempt {
  id            String   @id @default(cuid())
  surface       String
  identifierHash String
  attemptedAt   DateTime @default(now())

  @@index([surface, identifierHash, attemptedAt])
}

model OrderRecord {
  id                String              @id @default(cuid())
  orderNumber       String              @unique
  checkoutMode      CheckoutMode
  checkoutSessionId String              @unique
  paymentIntentId   String?             @unique
  status            OrderStatus
  paymentStatus     PaymentStatus
  customerEmail     String?
  shippingAddress   Json
  promoCode         String?
  discountUsd       Decimal             @default(0) @db.Decimal(10, 2)
  subtotalUsd       Decimal             @db.Decimal(10, 2)
  shippingUsd       Decimal             @db.Decimal(10, 2)
  taxUsd            Decimal             @db.Decimal(10, 2)
  totalUsd          Decimal             @db.Decimal(10, 2)
  currency          String              @db.VarChar(3)
  stripeEventId     String
  stripeEventType   String
  placedAt          DateTime            @default(now())
  fulfillmentExecutions FulfillmentExecutionRecord[]
  lineItems         OrderLineItemRecord[]
  promoRedemptions  PromoRedemptionRecord[]

  @@index([customerEmail])
  @@index([placedAt])
}

model FulfillmentExecutionRecord {
  id          String      @id @default(cuid())
  orderId      String
  trigger      String
  orderStatus  String
  actionKey    String
  actionLabel  String
  resultLabel  String
  notes        String
  createdAt    DateTime   @default(now())
  order        OrderRecord @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, trigger, orderStatus])
  @@index([orderId, createdAt])
}

model OrderLineItemRecord {
  id         String      @id @default(cuid())
  orderId    String
  cartItemId String
  productId  String
  productType String
  name       String
  slug       String
  priceUsd   Decimal     @db.Decimal(10, 2)
  quantity   Int
  variant    Json?
  order      OrderRecord @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model CatalogProduct {
  id               String          @id @default(cuid())
  type             String
  slug             String
  name             String
  category         ProductCategory
  description      String          @db.Text
  priceUsd         Decimal         @db.Decimal(10, 2)
  origin           String
  status           String
  images           Json
  materials        Json
  palette          Json?
  seoTitle         String
  seoDescription   String          @db.Text
  rugStyle         String?
  dimensionsCm     Json?
  weightKg         Decimal?        @db.Decimal(10, 2)
  fixedQuantity    Int?
  inventory        Int?
  lowStockThreshold Int?
  variants         Json?
  notifyMeEnabled  Boolean?
  homepageFeatured Boolean         @default(false)
  homepageRank     Int?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([slug, category])
  @@index([status])
  @@index([category, status])
  @@index([type, status])
  @@index([homepageFeatured, homepageRank])
}


model SeoSetting {
  id            String   @id @default(cuid())
  entityType    String
  entityKey     String
  title         String?
  description   String?  @db.Text
  canonicalUrl  String?
  robotsIndex   Boolean?
  ogTitle       String?
  ogDescription String?  @db.Text
  ogImageUrl    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([entityType, entityKey])
  @@index([entityType])
}

model NewsletterSubscriberRecord {
  id                 String   @id @default(cuid())
  email              String   @unique
  source             String
  status             String
  mailchimpAudienceId String?
  mailchimpMemberId  String?
  tags               Json
  consentedAt        DateTime?
  unsubscribedAt     DateTime?
  lastSyncedAt       DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model PromoRecord {
  id               String         @id @default(cuid())
  code             String         @unique
  type             PromoType
  amount           Decimal        @db.Decimal(10, 2)
  active           Boolean        @default(true)
  startsAt         DateTime?
  endsAt           DateTime?
  usageLimit       Int?
  usageCount       Int            @default(0)
  minimumSubtotalUsd Decimal?     @db.Decimal(10, 2)
  scopeType        PromoScopeType @default(all)
  scopeCategory    ProductCategory?
  scopeProductIds  Json?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  redemptions      PromoRedemptionRecord[]

  @@index([active, code])
}

model PromoRedemptionRecord {
  id            String      @id @default(cuid())
  promoId       String
  orderId       String?
  customerEmail String?
  code          String
  discountUsd   Decimal     @db.Decimal(10, 2)
  redeemedAt    DateTime    @default(now())
  promo         PromoRecord @relation(fields: [promoId], references: [id], onDelete: Cascade)
  order         OrderRecord? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([promoId, redeemedAt])
  @@index([orderId])
}

model HomepageContentRecord {
  id        String   @id @default(cuid())
  key       String   @unique
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogAuthorRecord {
  id        String   @id @default(cuid())
  key       String   @unique
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
