generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProductCategory {
  rugs
  poufs
  pillows
  decor
  vintage
}

enum AdminRole {
  admin
  editor
  viewer
}

enum CheckoutMode {
  guest
}

enum OrderStatus {
  pending
  paid
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  authorized
  paid
  failed
  refunded
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  firstName     String?
  lastName      String?
  role          AdminRole?
  accounts      Account[]
  passwordResetTokens PasswordResetToken[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model LoginRateLimitAttempt {
  id            String   @id @default(cuid())
  surface       String
  identifierHash String
  attemptedAt   DateTime @default(now())

  @@index([surface, identifierHash, attemptedAt])
}

model OrderRecord {
  id                String              @id @default(cuid())
  orderNumber       String              @unique
  checkoutMode      CheckoutMode
  checkoutSessionId String              @unique
  paymentIntentId   String?             @unique
  status            OrderStatus
  paymentStatus     PaymentStatus
  customerEmail     String?
  shippingAddress   Json
  subtotalUsd       Decimal             @db.Decimal(10, 2)
  shippingUsd       Decimal             @db.Decimal(10, 2)
  taxUsd            Decimal             @db.Decimal(10, 2)
  totalUsd          Decimal             @db.Decimal(10, 2)
  currency          String              @db.VarChar(3)
  stripeEventId     String
  stripeEventType   String
  placedAt          DateTime            @default(now())
  fulfillmentExecutions FulfillmentExecutionRecord[]
  lineItems         OrderLineItemRecord[]

  @@index([customerEmail])
  @@index([placedAt])
}

model FulfillmentExecutionRecord {
  id          String      @id @default(cuid())
  orderId      String
  trigger      String
  orderStatus  String
  actionKey    String
  actionLabel  String
  resultLabel  String
  notes        String
  createdAt    DateTime   @default(now())
  order        OrderRecord @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, trigger, orderStatus])
  @@index([orderId, createdAt])
}

model OrderLineItemRecord {
  id         String      @id @default(cuid())
  orderId    String
  cartItemId String
  productId  String
  productType String
  name       String
  slug       String
  priceUsd   Decimal     @db.Decimal(10, 2)
  quantity   Int
  variant    Json?
  order      OrderRecord @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model CatalogProduct {
  id               String          @id @default(cuid())
  type             String
  slug             String
  name             String
  category         ProductCategory
  description      String          @db.Text
  priceUsd         Decimal         @db.Decimal(10, 2)
  origin           String
  status           String
  images           Json
  materials        Json
  seoTitle         String
  seoDescription   String          @db.Text
  rugStyle         String?
  dimensionsCm     Json?
  weightKg         Decimal?        @db.Decimal(10, 2)
  fixedQuantity    Int?
  inventory        Int?
  lowStockThreshold Int?
  variants         Json?
  notifyMeEnabled  Boolean?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([slug, category])
  @@index([status])
  @@index([category, status])
  @@index([type, status])
}

model HomepageContentRecord {
  id        String   @id @default(cuid())
  key       String   @unique
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BlogAuthorRecord {
  id        String   @id @default(cuid())
  key       String   @unique
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
