{
  "name": "loom-hearth-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run prisma:migrate:deploy && next build",
    "build:release": "bash ./scripts/prisma-migrate-deploy.sh && npm run catalog:bootstrap && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "admin:promote-user": "node scripts/promote-admin-user.mjs",
    "catalog:import-launch-local": "node scripts/import-launch-products.mjs",
    "homepage:seed-featured": "node scripts/seed-homepage-featured-products.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "bash ./scripts/prisma-migrate-deploy.sh",
    "postinstall": "prisma generate",
    "catalog:bootstrap": "node scripts/bootstrap-launch-catalog.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.16.2",
    "next": "^15.2.0",
    "next-auth": "^4.24.13",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.2.0",
    "prisma": "^6.16.2",
    "typescript": "^5.7.2"
  }
}
